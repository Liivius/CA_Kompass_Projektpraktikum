        <mxCell id="Ys0LFPMxkC5Dg05WnkZF-232" parent="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" value="&lt;b style=&quot;text-align: left;&quot;&gt;Fazit Zweig IV&lt;/b&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;Support braucht fast immer mindestens kalibrierte Höflichkeit; häufig Stufe 2.&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;Empathie indirekt: Tonalität, Tempo, schnelle Lösung, klare Eskalation.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;Stufe 3 nur bei echter Wiederkehr / Historie.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="371" width="790" x="1290" y="1290" as="geometry" />
        </mxCell>
      </root>
