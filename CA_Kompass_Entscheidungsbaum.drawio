        <mxCell id="iba9eGXIdv3Bu6C7WvpI-182" parent="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" value="&lt;b style=&quot;text-align: left;&quot;&gt;Fazit Zweig III&lt;/b&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;Beratung ist dialogisch. Default: Stufe 2. Stufe 3 nur, wenn Wiederkehr, Wiedererkennung&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;text-align: left;&quot;&gt;und Rechtsraum wirklich geklärt sind. Stufe 0 fast nie sinnvoll.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="371" width="790" x="1170" y="1620" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
