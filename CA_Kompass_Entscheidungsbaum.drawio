  <diagram id="diag-2" name="00_Master">
    <mxGraphModel dx="2282" dy="1248" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3400" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=18;align=center;verticalAlign=middle;" value="Entscheidungsmodell für CA-Typ &amp; Persona-Stufe" vertex="1">
          <mxGeometry height="60" width="1040" x="1180" y="20" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;" value="⚠ Funktion vor Persona&lt;br&gt;&lt;br&gt;Persona ist Aufsatz, nicht Fundament. Erst wenn der Chatbot Anfragen zuverlässig versteht, korrekt beantwortet und stabil läuft, lohnt sich die Ausgestaltung der Persona." vertex="1">
          <mxGeometry height="150" width="620" x="40" y="100" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;" value="&lt;b&gt;Dominanzregeln / KO-Regeln&lt;/b&gt;&lt;br&gt;• F7 = A „klares System“ → Hard-Lock Stufe 0&lt;br&gt;• F7 = D + F13 = C/D → Deckel auf Stufe 2&lt;br&gt;• F10 = A (sensible Themen regelmäßig) → Deckel auf Stufe 2 für Memory-Features&lt;br&gt;• Voice-Pfade tendieren konservativer als Text-Pfade" vertex="1">
          <mxGeometry height="160" width="640" x="700" y="100" as="geometry" />
        </mxCell>
        <mxCell id="6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;Stufen-relevante Fragen&lt;/b&gt;&lt;br&gt;F1 Aufgabe · F2 Kanal · F4 Emotionslage · F5 Nutzungsfrequenz · F6 Markenrelevanz · F7 Persönlichkeitsgrad · F12 Interaktionsdauer · F13 Wiedererkennung" vertex="1">
          <mxGeometry height="120" width="620" x="1380" y="100" as="geometry" />
        </mxCell>
        <mxCell id="7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;Modifikatoren nach der Stufenwahl&lt;/b&gt;&lt;br&gt;F3 Zielgruppe · F8 Schnell vs. gut behandelt · F9 Eskalation · F10 sensible Themen · F11 Projektstand" vertex="1">
          <mxGeometry height="120" width="620" x="2040" y="100" as="geometry" />
        </mxCell>
        <mxCell id="8" parent="1" style="shape=rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=center;verticalAlign=middle;" value="Frage 1&lt;br&gt;&lt;b&gt;Was ist die Hauptaufgabe?&lt;/b&gt;" vertex="1">
          <mxGeometry height="120" width="560" x="1420" y="300" as="geometry" />
        </mxCell>
        <mxCell id="9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;Zweig I · Informationsbot&lt;/b&gt;&lt;br&gt;Default: Stufe 0–1&lt;br&gt;Aufwertung durch: Marke, emotionale Anfragen, Memory" vertex="1">
          <mxGeometry height="140" width="500" x="220" y="520" as="geometry" />
        </mxCell>
        <mxCell id="10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;Zweig II · Transaktionsbot&lt;/b&gt;&lt;br&gt;Default: Stufe 0–1&lt;br&gt;Aufwertung durch: Marke, emotionale Transaktionen, Wiederkehr &amp; Memory" vertex="1">
          <mxGeometry height="150" width="500" x="860" y="520" as="geometry" />
        </mxCell>
        <mxCell id="11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;Zweig III · Beratungsbot&lt;/b&gt;&lt;br&gt;Default: Stufe 2&lt;br&gt;Aufwertung zu Stufe 3 bei regelmäßiger Nutzung + Memory + Rechtsraum geklärt" vertex="1">
          <mxGeometry height="150" width="500" x="1500" y="520" as="geometry" />
        </mxCell>
        <mxCell id="12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;Zweig IV · Support / Beschwerde&lt;/b&gt;&lt;br&gt;Default: Stufe 2&lt;br&gt;Empathie indirekt: Tonalität + schnelle Lösung, nicht gespielte Gefühle" vertex="1">
          <mxGeometry height="150" width="500" x="2140" y="520" as="geometry" />
        </mxCell>
        <mxCell id="13" edge="1" parent="1" source="8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=11;" target="9" value="A · Fragen beantworten">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="14" edge="1" parent="1" source="8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=11;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="10" value="B · Vorgänge abwickeln">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1410" y="360" />
              <mxPoint x="1410" y="390" />
              <mxPoint x="1110" y="390" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="15" edge="1" parent="1" source="8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=11;" target="11" value="C · Beraten">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="16" edge="1" parent="1" source="8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;fontSize=11;" target="12" value="D · Beschwerden &amp; Support">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 0 · Ohne Persona&lt;/b&gt;&lt;br&gt;Rein funktional. Sinnvoll bei klaren Standard- oder Transaktionsfällen, wenn Persönlichkeit keinen Zusatznutzen bringt." vertex="1">
          <mxGeometry height="120" width="560" x="120" y="760" as="geometry" />
        </mxCell>
        <mxCell id="18" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 1 · Minimale Persona&lt;/b&gt;&lt;br&gt;Name + höflicher Grundton + klare KI-Kennzeichnung. Default-Empfehlung bei vielen alltagsnahen Use Cases." vertex="1">
          <mxGeometry height="120" width="560" x="760" y="760" as="geometry" />
        </mxCell>
        <mxCell id="19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 2 · Ausgeprägte Persona&lt;/b&gt;&lt;br&gt;Markenstimme, konsistenter Stil, kalibrierte Empathie, situative Anpassung an Zielgruppe und Gesprächslage." vertex="1">
          <mxGeometry height="120" width="560" x="1400" y="760" as="geometry" />
        </mxCell>
        <mxCell id="20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 3 · Voll adaptive Persona&lt;/b&gt;&lt;br&gt;Persistente Wiedererkennung, Präferenzlernen, stärkerer Beziehungscharakter. Nur bei echter Wiederkehr und geklärtem Rechtsraum." vertex="1">
          <mxGeometry height="120" width="560" x="2040" y="760" as="geometry" />
        </mxCell>
        <mxCell id="zuk3XkPT7rofp6i4jfUF-21" parent="1" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;" value="&lt;b style=&quot;text-align: left;&quot;&gt;Wissenschaftlicher Kurzbefund&lt;/b&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• Minimal soziale Hinweisreize reichen oft schon aus, um soziale Normen auszulösen.&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• Emotion + Markenrelevanz sind die stärksten Aufwertungs-Trigger zu Stufe 2.&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• Stufe 3 ist Spezialfall, nicht Default-Ziel.&lt;/span&gt;&lt;br style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;text-align: left;&quot;&gt;• KPI-Effekte von Persona sind nicht garantiert → im Zweifel konservativ wählen.&lt;/span&gt;" vertex="1">
          <mxGeometry height="410" width="830" x="690" y="920" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
