  </diagram>
  <diagram id="diag-233" name="05_Modifikatoren">
    <mxGraphModel dx="2282" dy="1248" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3400" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="234" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=18;align=center;verticalAlign=middle;" value="Modifikatoren nach der Stufenwahl" vertex="1">
          <mxGeometry height="60" width="900" x="1110" y="20" as="geometry" />
        </mxCell>
        <mxCell id="235" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;F3 · Zielgruppe&lt;/b&gt;&lt;br&gt;A jung, digital affin → lockerer, Emojis möglich, Duzen denkbar&lt;br&gt;B breite Öffentlichkeit → neutral, sparsame Emojis, eher Siezen&lt;br&gt;C älter / weniger technikaffin → kurze Sätze, wenige Fachbegriffe, sichtbare Hilfe&lt;br&gt;D Fachpublikum → höhere Informationsdichte, Fachbegriffe ok" vertex="1">
          <mxGeometry height="240" width="620" x="60" y="110" as="geometry" />
        </mxCell>
        <mxCell id="236" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;F8 · Schnell vs. gut behandelt&lt;/b&gt;&lt;br&gt;A schnell → kurze Antworten, wenige Floskeln&lt;br&gt;B gut behandelt → etwas mehr Beziehung / Begrüßung&lt;br&gt;C beides → Balance" vertex="1">
          <mxGeometry height="180" width="500" x="730" y="110" as="geometry" />
        </mxCell>
        <mxCell id="237" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;" value="&lt;b&gt;F9 · Eskalation&lt;/b&gt;&lt;br&gt;A sofort → niedrige Schwelle, aber Nutzen des CAs sinkt&lt;br&gt;B erst anders helfen → Standardpfad mit klaren Triggern&lt;br&gt;C Grenzen nennen + andere Kanäle → gut für Info-Fälle&lt;br&gt;D kein Fallback → Warnung vor Endlos-Loops" vertex="1">
          <mxGeometry height="210" width="520" x="1270" y="110" as="geometry" />
        </mxCell>
        <mxCell id="238" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;" value="&lt;b&gt;F10 · Sensible Themen&lt;/b&gt;&lt;br&gt;A regelmäßig → strikte Transparenz, Vorsicht bei Memory / Sentiment-Analyse&lt;br&gt;B gelegentlich → Memory nur mit klaren Regeln / Einwilligung&lt;br&gt;C selten → Standard" vertex="1">
          <mxGeometry height="190" width="520" x="1830" y="110" as="geometry" />
        </mxCell>
        <mxCell id="239" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;" value="&lt;b&gt;F11 · Projektstand&lt;/b&gt;&lt;br&gt;A Planung → volle Konzeption&lt;br&gt;B verbessern → Fokus auf Problemstellen&lt;br&gt;C feinjustieren → Persona-Tuning / Stil / Eskalationslogik" vertex="1">
          <mxGeometry height="170" width="500" x="2390" y="110" as="geometry" />
        </mxCell>
        <mxCell id="240" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 0 · Gestaltungsfazit&lt;/b&gt;&lt;br&gt;• Keine menschliche Inszenierung nötig&lt;br&gt;• Klare KI-Kennzeichnung reicht&lt;br&gt;• Sprache nüchtern, kurz, fehlerarm&lt;br&gt;• Besonders passend bei Standard-FAQ, Status, Buchung" vertex="1">
          <mxGeometry height="190" width="620" x="80" y="430" as="geometry" />
        </mxCell>
        <mxCell id="241" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 1 · Gestaltungsfazit&lt;/b&gt;&lt;br&gt;• Name + freundliche Begrüßung + transparente KI-Rolle&lt;br&gt;• Sachlich, höflich, nicht zu gesprächig&lt;br&gt;• Gute Default-Stufe für viele kundennahe Fälle" vertex="1">
          <mxGeometry height="180" width="620" x="760" y="430" as="geometry" />
        </mxCell>
        <mxCell id="242" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 2 · Gestaltungsfazit&lt;/b&gt;&lt;br&gt;• Konsistente Markenstimme, bewusstes Wording, situative Anpassung&lt;br&gt;• Empathie über Tonalität und Lösungsorientierung, nicht über gespielte Gefühle&lt;br&gt;• Klare Eskalationsgrenzen und Erwartungsmanagement" vertex="1">
          <mxGeometry height="200" width="620" x="1440" y="430" as="geometry" />
        </mxCell>
        <mxCell id="243" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;" value="&lt;b&gt;Stufe 3 · Gestaltungsfazit&lt;/b&gt;&lt;br&gt;• Nur sinnvoll bei echter Wiederkehr und erkennbarem Mehrwert&lt;br&gt;• Wiedererkennung, Präferenzlernen, Historie / Memory&lt;br&gt;• Datenschutz, Transparenz und menschliche Aufsicht müssen geklärt sein" vertex="1">
          <mxGeometry height="200" width="620" x="2120" y="430" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="legend" name="99_Legende">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="2200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="leg_100" value="Legende zum Entscheidungsmodell" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=20;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="1200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="leg_101" value="Diese Seite erklärt die Symbole, Farben und Regeln, die in den Zweigen 01–05 verwendet werden. Sie ist unabhängig von den Zweigen und dient als Referenz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=12;align=center;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_102" value="1 · Formen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="300" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_103" value="F?&#xa;Entscheidungsfrage" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_104" value="Raute · Entscheidungsknoten&#xa;Enthält eine der 13 Fragen aus dem Fragebogen. Aus ihr gehen Antwortpfade heraus." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="230" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_105" value="A · Antwortoption" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=center;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="leg_106" value="Helles Rechteck · Antwortoption&#xa;Zeigt eine konkrete Antwort auf die vorhergehende Frage." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="330" width="500" height="60" as="geometry" />
        </mxCell>
        <mxCell id="leg_107" value="PFAD X-Y · STUFE n&#xa;Empfehlungstext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="410" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_108" value="Gerundetes Rechteck · Endknoten (Pfad-Ergebnis)&#xa;Empfehlung am Ende eines Pfads. Farbe zeigt die empfohlene Persona-Stufe (siehe Sektion 2 unten). Enthält Pfad-ID, Stufe und Kurz-Empfehlung." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="410" width="500" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_109" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="40" y="520.0" width="10" height="10" as="geometry" />
        </mxCell>
        <mxCell id="leg_110" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="170" y="520.0" width="10" height="10" as="geometry" />
        </mxCell>
        <mxCell id="leg_111" value="A · Text" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#333333;fontSize=11;" edge="1" parent="1" source="leg_109" target="leg_110">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="leg_112" value="Pfeil · Entscheidungspfad&#xa;Verbindet Frage → Antwort → Folgefrage bzw. Endknoten. Die Beschriftung nennt die Antwortoption (z. B. „A · Text“)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="200" y="510" width="500" height="50" as="geometry" />
        </mxCell>
        <mxCell id="leg_113" value="2 · Persona-Stufen (Endknoten-Farben)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="600" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_114" value="Stufe 0 · Ohne Persona" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#666666;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="690" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_115" value="Rein funktional. Kein Name, neutraler Stil, nur Systemidentität. Sinnvoll bei rein transaktionalen Fällen, wo Persönlichkeit keinen Mehrwert bringt." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="690" width="900" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_116" value="Stufe 1 · Minimale Persona" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_117" value="Name + KI-Kennzeichnung + höflicher Grundton. Media-Equation-Effekt: minimale Reize reichen oft aus. Default-Empfehlung im Zweifel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="790" width="900" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_118" value="Stufe 2 · Ausgeprägte Persona" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="890" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_119" value="Definierter Sprachstil, Corporate Identity, kalibrierte Empathie. Für Beratung, Support, markenrelevante Interaktion." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="890" width="900" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_120" value="Stufe 3 · Voll adaptive Persona" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="990" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_121" value="Persistente Wiedererkennung, Präferenzlernen, Beziehungscharakter. Nur bei regelmäßiger Nutzung, Memory-Wunsch und geklärtem Rechtsraum." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="990" width="900" height="80" as="geometry" />
        </mxCell>
        <mxCell id="leg_122" value="3 · Hinweis- und Regelfarben" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1120" width="500" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_123" value="⚠ Warnung / Widerspruch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1180" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_124" value="Rot markiert. Erscheint an Pfaden mit logischem Widerspruch (z. B. F1=Beratung + F7=System) oder an permanenten Hinweisen wie „Funktion vor Persona“." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="1180" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_125" value="Dominanz- / KO-Regel · Modifikator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1270" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_126" value="Orange markiert. Kennzeichnet Regeln, die einzelne Pfade überschreiben (z. B. F7=A → Hard-Lock Stufe 0) oder Modifikatoren, die Ausgestaltung innerhalb einer Stufe ändern." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="1270" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_127" value="Titel- / Intro-Block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1360" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_128" value="Blau markiert. Überschriften, Zweig-Einleitungen und übergeordnete Erklärtexte." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="340" y="1360" width="900" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_129" value="4 · Pfad-IDs lesen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1480" width="400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_130" value="Beispiel · PFAD IV-8 · STUFE 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1540" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="leg_131" value="Die Pfad-ID besteht aus drei Teilen:&#xa;&#xa;• Römische Ziffer (I–IV) = Zweig · I=Info, II=Transaktion, III=Beratung, IV=Support&#xa;• Arabische Ziffer = laufende Nummer innerhalb des Zweigs&#xa;• STUFE 0–3 = empfohlene Persona-Stufe (Farbe entspricht Sektion 2)&#xa;&#xa;Beispiel IV-8 = Zweig Support, Pfad Nr. 8, Stufe 2 (= Lena-Pfad aus dem Konzeptionstext)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="460" y="1540" width="780" height="160" as="geometry" />
        </mxCell>
        <mxCell id="leg_132" value="5 · Rolle der 13 Fragen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1740" width="400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_133" value="Stufen-relevant (bilden die Stufe)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1800" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_134" value="F1 Hauptaufgabe · F2 Kanal · F4 Emotionslage · F5 Nutzungsfrequenz · F6 Markenrelevanz · F7 Persönlichkeitsgrad · F12 Interaktionsdauer · F13 Wiedererkennung" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="1850" width="600" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_135" value="Modifikatoren (nur Ausgestaltung)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="1800" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_136" value="F3 Zielgruppe · F8 Schnell vs. gut behandelt · F9 Eskalation · F10 Sensible Themen · F11 Projektstand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="660" y="1850" width="580" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_137" value="6 · Abkürzungen in Belegen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="1950" width="400" height="36" as="geometry" />
        </mxCell>
        <mxCell id="leg_138" value="Experteninterviews" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="2010" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_139" value="E1 bis E14 = Experten 1 bis 14 aus dem qualitativen Teil (Arbeitspaket 2). Zitate sind kursiv und mit Experten-Nummer in Klammern markiert." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="2060" width="600" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_140" value="Literatur (AP 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="2010" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_141" value="Autor (Jahr). Zentrale Werke: Völkel (2022), Mehri et al. (2026), Chhikara et al. (2025), Kim et al. (2019), de Gennaro et al. (2020), Silva &amp; Canedo (2023)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="660" y="2060" width="580" height="70" as="geometry" />
        </mxCell>
        <mxCell id="leg_142" value="Regulatorisch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=center;fontColor=#000000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="2150" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="leg_143" value="EU-KI-VO = EU-Verordnung 2024/1689 (KI-Verordnung), mit Artikel-Nummer. DSGVO = Datenschutz-Grundverordnung." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;fontSize=11;align=left;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="40" y="2200" width="1200" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
